{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "moduleResolution": "node",
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "libsystem.*": [
        "src/libsystem/types/libsystem/*"
      ]
    },
    "types": ["@jackmacwindows/lua-types/cc-5.2"]
  },
  "tstl": {
    "luaTarget": "CC-5.2",
    "luaLibImport": "inline",
    "noImplicitSelf": true,
  }
}